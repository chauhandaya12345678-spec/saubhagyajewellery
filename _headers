# Cloudflare Pages cache rules.
# Format: glob, then one or more header lines, indented.

# API responses - cache briefly so price edits go live within a minute.
/api/products*
  Cache-Control: public, max-age=60, must-revalidate

# Product photos - immutable, cache for a year (filename changes if content changes).
# Images will move to R2 in future; local fallback still cached aggressively.
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Site styles + framework - cache for a day.
/site.css
  Cache-Control: public, max-age=86400
/support.js
  Cache-Control: public, max-age=86400
/catalog.js
  Cache-Control: public, max-age=86400

# HTML pages - revalidate every few minutes so deploys reach users quickly.
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Build artifacts (fallback catalog JSON) - private, no cache.
/build/*
  Cache-Control: private, no-cache, no-store, must-revalidate

# Security headers, applied to everything.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(self "https://checkout.razorpay.com"), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), fullscreen=(self), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  X-XSS-Protection: 1; mode=block
  X-DNS-Prefetch-Control: on
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://checkout.razorpay.com https://www.googletagmanager.com https://www.google-analytics.com https://www.gstatic.com https://www.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://api.razorpay.com https://checkout.razorpay.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.googleapis.com https://api.postalpincode.in https://*.google-analytics.com https://www.googletagmanager.com https://www.gstatic.com https://www.google.com https://recaptchaenterprise.googleapis.com https://firebaseinstallations.googleapis.com https://content-firebaseappcheck.googleapis.com; frame-src https://checkout.razorpay.com https://api.razorpay.com https://www.google.com https://recaptcha.google.com; object-src 'none'; base-uri 'self'; form-action 'self' https://checkout.razorpay.com; frame-ancestors 'self'

# Ban search engines from account/cart/checkout via header too (belt + robots.txt).
/cart*
  X-Robots-Tag: noindex, follow
/checkout*
  X-Robots-Tag: noindex, follow
/account*
  X-Robots-Tag: noindex, follow
/signin*
  X-Robots-Tag: noindex, follow
/signup*
  X-Robots-Tag: noindex, follow
/success*
  X-Robots-Tag: noindex, follow
/api/*
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff

# Positive X-Robots-Tag on all indexable HTML — audit tools expect it explicitly.
# Also enables large image + snippet previews in Google SERP.
/
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/index.html
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/categories*
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/product*
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/gifting*
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/blogs*
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/about*
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/contact*
  X-Robots-Tag: index, follow, max-image-preview:large, max-snippet:-1
/track-orders*
  X-Robots-Tag: index, follow
/shipping-and-returns*
  X-Robots-Tag: index, follow
/privacy-policy*
  X-Robots-Tag: index, follow
/terms*
  X-Robots-Tag: index, follow
/trust*
  X-Robots-Tag: index, follow

# Long cache for manifest + web app icons
/manifest.json
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json
/.well-known/security.txt
  Cache-Control: public, max-age=86400
  Content-Type: text/plain; charset=utf-8

