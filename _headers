# Cloudflare Pages cache rules.
# Format: glob, then one or more header lines, indented.

# API responses - cache briefly so price edits go live within a minute.
/api/products*
  Cache-Control: public, max-age=60, must-revalidate

# Product photos - immutable, cache for a year (filename changes if content changes).
# Images will move to R2 in future; local fallback still cached aggressively.
/images/*
  Cache-Control: public, max-age=31536000, immutable

# Site styles + framework - cache for a day.
/site.css
  Cache-Control: public, max-age=86400
/support.js
  Cache-Control: public, max-age=86400
/catalog.js
  Cache-Control: public, max-age=86400

# HTML pages - revalidate every few minutes so deploys reach users quickly.
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# Build artifacts (fallback catalog JSON) - private, no cache.
/build/*
  Cache-Control: private, no-cache, no-store, must-revalidate

# Security headers, applied to everything.
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(self "https://checkout.razorpay.com"), usb=(), magnetometer=(), gyroscope=(), accelerometer=(), fullscreen=(self), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  X-XSS-Protection: 1; mode=block
  X-DNS-Prefetch-Control: on

# Ban search engines from account/cart/checkout via header too (belt + robots.txt).
/cart*
  X-Robots-Tag: noindex, follow
/checkout*
  X-Robots-Tag: noindex, follow
/account*
  X-Robots-Tag: noindex, follow
/signin*
  X-Robots-Tag: noindex, follow
/signup*
  X-Robots-Tag: noindex, follow
/success*
  X-Robots-Tag: noindex, follow
/api/*
  X-Robots-Tag: noindex, nofollow
  X-Content-Type-Options: nosniff

